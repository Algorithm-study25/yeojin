import sys
input = sys.stdin.readline

N,M = map(int, input().split())

arr = list(range(1, N+1))

result = []

def dfs(start):
    if len(result) == M:
        print(*result)
        return
    
    for i in range(start, N+1):
        result.append(i)
        dfs(i + 1)
        result.pop()

dfs(1)
